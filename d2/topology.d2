direction: right

# ##################################
# USERS
# ##################################

Vedení: Vedení {
  shape: rectangle
  icon: https://icons.terrastruct.com/azure%2FGeneral%20Service%20Icons%2FUser%20Icon.svg
  style: {
    font-size: 22
  }
  width: 180
  height: 100
}

Administrátoři: Administrátoři {
  shape: rectangle
  icon: https://icons.terrastruct.com/azure%2FGeneral%20Service%20Icons%2FUser%20Resource.svg
  style: {
    font-size: 22
  }
  width: 180
  height: 100
}

Dispečeři: Dispečeři {
  shape: rectangle
  icon: https://icons.terrastruct.com/azure%2FGeneral%20Service%20Icons%2FUser%20Privacy.svg
  style: {
